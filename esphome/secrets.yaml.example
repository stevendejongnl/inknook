wifi_ssid: "YourNetwork"
wifi_password: "yourpassword"

# URL to the FastAPI backend's BMP endpoint
# Use NodePort IP for ESP32 on LAN: http://<node-ip>:<nodeport>/display.bmp
# Use local dev IP for testing:     http://192.168.1.x:8000/display.bmp
backend_url: "http://192.168.1.x:8000/display.bmp"

# OTA update password (also used as fallback AP password)
ota_password: "changeme"
